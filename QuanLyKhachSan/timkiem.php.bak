                    ['q' => 'phố cổ', 'label' => 'Phố Cổ — Hà Nội', 'icon' => 'fa-landmark', 'color' => '#ef4444', 'image' => 'https://vj-prod-website-cms.s3.ap-southeast-1.amazonaws.com/shutterstock1391898416-1646649508378.png', 'desc' => 'Văn hóa, di sản, Hồ Gươm'],
