<?php
session_start();
date_default_timezone_set('Asia/Ho_Chi_Minh');
require_once 'config/database.php';

// Thuật toán Recommendation System Nâng Cao (Content-based Filtering)
$recommendations = [];
if (isset($_SESSION['user_id']) && $_SESSION['role'] == 'khach') {
    $userid = $_SESSION['user_id'];
    // 1. Phân tích lịch sử đặt phòng của khách hàng
    $sql_history = "SELECT lp.MaLoai, lp.GiaPhong, lp.TienNghi, lp.SoNguoiToiDa 
                    FROM DatPhong dp 
                    JOIN KhachHang kh ON dp.MaKH = kh.MaKH 
                    JOIN Phong p ON dp.MaPhong = p.MaPhong 
                    JOIN LoaiPhong lp ON p.MaLoai = lp.MaLoai
                    WHERE kh.MaTK = $userid AND dp.TrangThai IN ('Đang ở', 'Đã thanh toán')";
    $res_history = $conn->query($sql_history);
    
    if ($res_history && $res_history->num_rows > 0) {
        $avg_price = 0;
        $max_guest = 0;
        $amenities = [];
        $count = 0;
        while ($row = $res_history->fetch_assoc()) {
            $avg_price += $row['GiaPhong'];
            if ($row['SoNguoiToiDa'] > $max_guest) $max_guest = $row['SoNguoiToiDa'];
            $items = array_map('trim', explode(',', $row['TienNghi']));
            foreach($items as $i) $amenities[$i] = ($amenities[$i] ?? 0) + 1;
            $count++;
        }
        $avg_price = $avg_price / $count;
        
        // Trích xuất 2 tiện nghi được quan tâm nhất
        arsort($amenities);
        $top_amenities = array_slice(array_keys($amenities), 0, 2);
        
        // 2. Chấm điểm SimilarityScore cho các phòng trống
        $price_min = $avg_price * 0.7; // +- 30-50%
        $price_max = $avg_price * 1.5;
        
        $amenity_sql_parts = [];
        foreach($top_amenities as $a) {
            $amenity_sql_parts[] = "IF(lp.TienNghi LIKE '%" . $conn->real_escape_string($a) . "%', 2, 0)";
        }
        $amenity_score_sql = count($amenity_sql_parts) > 0 ? implode(" + ", $amenity_sql_parts) : "0";
        
        $sql_sug = "SELECT p.*, lp.TenLoai, lp.GiaPhong, lp.HinhAnh, lp.TienNghi, lp.SoNguoiToiDa,
                    (
                      IF(lp.GiaPhong BETWEEN $price_min AND $price_max, 2, 0) +
                      IF(lp.SoNguoiToiDa = $max_guest OR lp.SoNguoiToiDa = $max_guest + 1, 2, 0) + 
                      ($amenity_score_sql)
                    ) as SimilarityScore
                    FROM Phong p 
                    JOIN LoaiPhong lp ON p.MaLoai = lp.MaLoai 
                    WHERE p.TrangThai = 'Trống'
                    ORDER BY SimilarityScore DESC, lp.GiaPhong ASC LIMIT 4";
                    
        $rec_result = $conn->query($sql_sug);
        while ($r = $rec_result->fetch_assoc()) $recommendations[] = $r;
    }
}

// Fallback: Nổi bật
if (count($recommendations) == 0) {
    // Nếu hết phòng trống thì show phòng bất kỳ cũng được (demo)
    $res = $conn->query("SELECT p.*, lp.TenLoai, lp.GiaPhong, lp.HinhAnh, lp.TienNghi, lp.SoNguoiToiDa 
                         FROM Phong p JOIN LoaiPhong lp ON p.MaLoai = lp.MaLoai 
                         WHERE p.TrangThai = 'Trống' ORDER BY lp.GiaPhong DESC LIMIT 4");
    while ($r = $res->fetch_assoc()) $recommendations[] = $r;
}
?>
