            <?php if ($error): ?>
            <div class="alert-error">
                <i class="fa-solid fa-circle-exclamation"></i>
                <?= htmlspecialchars($error) ?>
            </div>
            <?php endif; ?>

            <form method="POST" id="loginForm">
                <div class="form-floating-custom">
                    <label>Tên đăng nhập</label>
                    <div class="input-wrap">
                        <div class="input-icon"><i class="fa-regular fa-user"></i></div>
                        <input type="text" name="username" placeholder="Nhập tên đăng nhập" required
                               value="<?= htmlspecialchars($_POST['username'] ?? '') ?>" autocomplete="username">
                    </div>
                </div>
                <div class="form-floating-custom">
                    <label>Mật khẩu</label>
                    <div class="input-wrap">
                        <div class="input-icon"><i class="fa-solid fa-lock"></i></div>
                        <input type="password" name="password" id="pwInput" placeholder="Nhập mật khẩu" required autocomplete="current-password">
                        <div class="toggle-pw" onclick="togglePassword()" title="Hiện/ẩn mật khẩu">
                            <i class="fa-regular fa-eye" id="eyeIcon"></i>
                        </div>
                    </div>
                </div>

                <button type="submit" name="login" class="btn-login mt-2">
                    <span><i class="fa-solid fa-right-to-bracket me-2"></i>Đăng Nhập</span>
                </button>
            </form>

            <div class="divider">hoặc</div>

            <div class="register-link">
