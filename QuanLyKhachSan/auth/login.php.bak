        /* Stats */
        .left-stats {
            display: flex;
            gap: 40px;
            margin-top: 40px;
        }
        .stat-item { text-align: center; }
        .stat-num { font-size: 2rem; font-weight: 800; }
        .stat-label { font-size: 0.75rem; opacity: 0.75; text-transform: uppercase; letter-spacing: 1px; }

        /* ========= RIGHT PANEL ========= */
        .login-right {
            width: 480px;
