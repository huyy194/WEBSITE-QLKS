        }
        /* Floating orbs */
        .orb {
            position: absolute;
            border-radius: 50%;
            opacity: 0.15;
            animation: floatOrb 6s ease-in-out infinite;
        }
        .orb-1 { width: 80px; height: 80px; background: white; top: 20%; left: 10%; animation-delay: 0s; }
        .orb-2 { width: 50px; height: 50px; background: white; top: 60%; left: 80%; animation-delay: 2s; }
        .orb-3 { width: 120px; height: 120px; background: white; bottom: 15%; left: 20%; animation-delay: 4s; }
        .orb-4 { width: 40px; height: 40px; background: white; top: 30%; right: 10%; animation-delay: 1s; }
        @keyframes floatOrb {
            0%, 100% { transform: translateY(0px) scale(1); }
            50% { transform: translateY(-20px) scale(1.05); }
        }

        /* Feature pills */
        .feature-pills {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 10px;
            margin-top: 28px;
